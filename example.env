# Copy this file to .env for local/dev usage:
# cp example.env .env
#
# Never commit real secrets in .env.

# Platform
STACCATO_HTTP_ADDR=:8080
STACCATO_NATS_URL=nats://127.0.0.1:4222
STACCATO_NATS_NKEY=/etc/staccato/nats/platform.nk
STACCATO_OBJECT_DIR=var/objects

# GitHub OAuth (required for platform login)
STACCATO_GITHUB_CLIENT_ID=replace-with-client-id
STACCATO_GITHUB_CLIENT_SECRET=replace-with-client-secret
STACCATO_GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback
# STACCATO_GITHUB_APP_ID=123456
# STACCATO_GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Set true when running behind HTTPS; keep false for local HTTP
STACCATO_SESSION_SECURE=false
