# Copy this file to .env for local/dev usage:
# cp example.env .env
#
# Never commit real secrets in .env.

# Platform
ENVOY_HTTP_ADDR=:8080
ENVOY_NATS_URL=nats://127.0.0.1:4222
ENVOY_OBJECT_DIR=var/objects

# GitHub OAuth (required for platform login)
ENVOY_GITHUB_CLIENT_ID=replace-with-client-id
ENVOY_GITHUB_CLIENT_SECRET=replace-with-client-secret
ENVOY_GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback

# Set true when running behind HTTPS; keep false for local HTTP
ENVOY_SESSION_SECURE=false
